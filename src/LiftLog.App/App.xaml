<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:LiftLog.App.Converters"
             xmlns:components="clr-namespace:LiftLog.App.Views.Components"
             xmlns:local="clr-namespace:LiftLog.App"
             x:Class="LiftLog.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <ControlTemplate x:Key="PageWithWorkoutBarTemplate">
                <Grid RowDefinitions="*,Auto">
                    <ContentPresenter
                        Grid.Row="0"
                        Content="{TemplateBinding Content}" />
                    <components:ActiveWorkoutBannerView Grid.Row="1" />
                </Grid>
            </ControlTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
