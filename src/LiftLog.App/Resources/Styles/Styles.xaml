<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:strings="clr-namespace:LiftLog.App.Resources.Strings">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
    </Style>

    <Style x:Key="AppNameStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="CharacterSpacing" Value="0" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
        <Setter Property="HorizontalTextAlignment" Value="Start" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="25" />
        <Setter Property="CharacterSpacing" Value="0.5" />
        <Setter Property="LineHeight" Value="1.1" />
        <Setter Property="SemanticProperties.HeadingLevel" Value="Level1" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="CharacterSpacing" Value="1.2" />
        <Setter Property="SemanticProperties.HeadingLevel" Value="Level2" />
    </Style>

    <Style x:Key="HomeSectionTitleStyle" TargetType="Label" BasedOn="{StaticResource SectionTitleStyle}">
        <Setter Property="FontSize" Value="19" />
        <Setter Property="CharacterSpacing" Value="2" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CharacterSpacing" Value="0.2" />
    </Style>

    <Style x:Key="BodyMutedStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="LineHeight" Value="1.25" />
    </Style>

    <Style x:Key="CaptionStyle" TargetType="Label" BasedOn="{StaticResource BodyMutedStyle}">
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="AccentCaptionStyle" TargetType="Label" BasedOn="{StaticResource CaptionStyle}">
        <Setter Property="TextColor" Value="{StaticResource Accent}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style x:Key="MetricValueStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="19" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="MetricLabelStyle" TargetType="Label" BasedOn="{StaticResource CaptionStyle}">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
    </Style>

    <Style x:Key="RuleStyle" TargetType="BoxView">
        <Setter Property="Color" Value="{StaticResource OutlineLight}" />
        <Setter Property="HeightRequest" Value="1" />
    </Style>

    <Style x:Key="AccentRuleStyle" TargetType="BoxView" BasedOn="{StaticResource RuleStyle}">
        <Setter Property="Color" Value="{StaticResource Accent}" />
        <Setter Property="HeightRequest" Value="2" />
    </Style>

    <Style x:Key="FormLabelStyle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="ErrorLabelStyle" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Padding" Value="16" />
        <Setter Property="MinimumHeightRequest" Value="72" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource OutlineLight}, Dark={StaticResource OutlineDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Padding" Value="24" />
        <Setter Property="MinimumHeightRequest" Value="0" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="Stroke" Value="{StaticResource OutlineLight}" />
    </Style>

    <Style x:Key="StatusCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="MinimumHeightRequest" Value="0" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="WorkoutSetCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="MinimumHeightRequest" Value="0" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceRaisedLight}" />
    </Style>

    <Style x:Key="ExerciseImageFrameStyle" TargetType="Border">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceRaisedDark}" />
        <Setter Property="Stroke" Value="{StaticResource OutlineDark}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="10" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="MinimumHeightRequest" Value="50" />
        <Setter Property="Padding" Value="18,14" />
        <Setter Property="CharacterSpacing" Value="0.8" />
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
        <Setter Property="TextColor" Value="{StaticResource Black}" />
        <Setter Property="BorderColor" Value="{StaticResource AccentDark}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource OutlineLight}, Dark={StaticResource OutlineDark}}" />
                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="BorderColor" Value="{StaticResource OutlineLight}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="BorderColor" Value="{StaticResource Danger}" />
    </Style>

    <Style x:Key="CompactButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="CompactPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="Padding" Value="14,9" />
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style x:Key="CompactDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="BorderColor" Value="{StaticResource Danger}" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceLight}, Dark={StaticResource SurfaceDark}}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style TargetType="SearchBar">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceLight}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimaryLight}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondaryLight}" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Accent}" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style TargetType="Switch">
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="MinimumWidthRequest" Value="48" />
        <Setter Property="OnColor" Value="{StaticResource Accent}" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="SemanticProperties.Description" Value="{x:Static strings:AppText.Loading}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundLight}, Dark={StaticResource BackgroundDark}}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Accent}" />
        <Setter Property="Shell.TitleColor" Value="{AppThemeBinding Light={StaticResource TextPrimaryLight}, Dark={StaticResource TextPrimaryDark}}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource BackgroundLight}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource Accent}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{AppThemeBinding Light={StaticResource TextSecondaryLight}, Dark={StaticResource TextSecondaryDark}}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>
</ResourceDictionary>
