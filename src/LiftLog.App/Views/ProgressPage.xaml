<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LiftLog.App.Views.ProgressPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LiftLog.App.Controls"
    xmlns:strings="clr-namespace:LiftLog.App.Resources.Strings"
    xmlns:viewModels="clr-namespace:LiftLog.App.ViewModels"
    xmlns:components="clr-namespace:LiftLog.App.Views.Components"
    x:DataType="viewModels:ProgressViewModel"
    Title="{x:Static strings:AppText.ExerciseProgressTitle}">

    <ContentPage.Resources>
        <Style x:Key="ProgressMetricButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="BorderColor" Value="Transparent" />
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceRaisedDark}" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <CollectionView
            Grid.Row="0"
            ItemsSource="{Binding Evolution}"
            SelectionMode="None"
            ItemSizingStrategy="MeasureFirstItem">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>

            <CollectionView.Header>
                <VerticalStackLayout
                    x:DataType="viewModels:ProgressViewModel"
                    Padding="20,12,20,14"
                    Spacing="18">
                    <Picker
                        Title="{x:Static strings:AppText.SelectProgressExercise}"
                        SemanticProperties.Description="{x:Static strings:AppText.SelectProgressExercise}"
                        ItemsSource="{Binding ExerciseOptions}"
                        ItemDisplayBinding="{Binding Name}"
                        SelectedItem="{Binding SelectedExercise}"
                        SelectedIndexChanged="OnExerciseChanged" />

                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                        <Border Style="{StaticResource StatusCardStyle}">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="{x:Static strings:AppText.BestWeightLabel}" Style="{StaticResource CaptionStyle}" />
                                <Label Text="{Binding BestWeight}" Style="{StaticResource SectionTitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource StatusCardStyle}">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="{x:Static strings:AppText.BestRepetitionsLabel}" Style="{StaticResource CaptionStyle}" />
                                <Label Text="{Binding BestRepetitions}" Style="{StaticResource SectionTitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource StatusCardStyle}">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="{x:Static strings:AppText.TotalVolumeLabel}" Style="{StaticResource CaptionStyle}" />
                                <Label Text="{Binding TotalVolume}" Style="{StaticResource SectionTitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource StatusCardStyle}">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="{x:Static strings:AppText.WorkoutsCountLabel}" Style="{StaticResource CaptionStyle}" />
                                <Label Text="{Binding WorkoutCount}" Style="{StaticResource SectionTitleStyle}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <Label Text="{x:Static strings:AppText.ExerciseTrendTitle}" Style="{StaticResource SectionTitleStyle}" />

                    <Grid HeightRequest="230">
                        <controls:TrainingChartView
                            Points="{Binding ChartPoints}"
                            Kind="Line"
                            SemanticProperties.Description="Exercise progress chart" />
                        <VerticalStackLayout
                            IsVisible="{Binding IsProgressEmpty}"
                            Spacing="5"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">
                            <Label
                                Text="{x:Static strings:AppText.NoProgressTitle}"
                                Style="{StaticResource CardTitleStyle}"
                                HorizontalTextAlignment="Center" />
                            <Label
                                Text="{x:Static strings:AppText.NoProgressDescription}"
                                Style="{StaticResource BodyMutedStyle}"
                                HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button
                            Text="{x:Static strings:AppText.WeightLabel}"
                            Command="{Binding SelectChartMetricCommand}"
                            CommandParameter="Weight"
                            Style="{StaticResource ProgressMetricButtonStyle}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsWeightSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                    <Setter Property="TextColor" Value="{StaticResource Black}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button
                            Grid.Column="1"
                            Text="{x:Static strings:AppText.VolumeLabel}"
                            Command="{Binding SelectChartMetricCommand}"
                            CommandParameter="Volume"
                            Style="{StaticResource ProgressMetricButtonStyle}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsVolumeSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                    <Setter Property="TextColor" Value="{StaticResource Black}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button
                            Grid.Column="2"
                            Text="{x:Static strings:AppText.RepsLabel}"
                            Command="{Binding SelectChartMetricCommand}"
                            CommandParameter="Reps"
                            Style="{StaticResource ProgressMetricButtonStyle}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsRepsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                    <Setter Property="TextColor" Value="{StaticResource Black}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>

                    <Label
                        Text="{x:Static strings:AppText.WorkoutHistoryTitle}"
                        IsVisible="{Binding HasProgress}"
                        Style="{StaticResource SectionTitleStyle}" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:ExerciseProgressPointItem">
                    <Border Margin="20,0" Style="{StaticResource CardStyle}">
                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="5" ColumnSpacing="12">
                            <Label Text="{Binding Date}" Style="{StaticResource CardTitleStyle}" />
                            <Label Grid.Column="1" Text="{Binding MaximumWeight}" Style="{StaticResource AccentCaptionStyle}" />
                            <Label Grid.Row="1" Text="{Binding Volume}" Style="{StaticResource CaptionStyle}" />
                            <Label Grid.Row="1" Grid.Column="1" Text="{Binding BestRepetitions}" Style="{StaticResource CaptionStyle}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.Footer>
                <Grid
                    x:DataType="viewModels:ProgressViewModel"
                    Margin="20,8,20,36"
                    IsVisible="{Binding HasError}"
                    ColumnDefinitions="*,Auto"
                    ColumnSpacing="10">
                    <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabelStyle}" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="{x:Static strings:AppText.Retry}" Command="{Binding RetryCommand}" Style="{StaticResource CompactButtonStyle}" />
                </Grid>
            </CollectionView.Footer>
        </CollectionView>

        <ActivityIndicator
            Grid.Row="0"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="{StaticResource Accent}"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            ZIndex="10" />
        <components:ActiveWorkoutBannerView x:Name="ActiveWorkoutBanner" Grid.Row="1" />
    </Grid>
</ContentPage>
