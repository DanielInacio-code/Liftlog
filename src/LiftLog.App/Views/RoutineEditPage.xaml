<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LiftLog.App.Views.RoutineEditPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LiftLog.App.Controls"
    xmlns:strings="clr-namespace:LiftLog.App.Resources.Strings"
    xmlns:viewModels="clr-namespace:LiftLog.App.ViewModels"
    xmlns:models="clr-namespace:LiftLog.Core.Models;assembly=LiftLog.Core"
    x:Name="RoutineEditPageRoot"
    x:DataType="viewModels:RoutineEditViewModel"
    ControlTemplate="{StaticResource PageWithWorkoutBarTemplate}"
    Shell.NavBarIsVisible="False"
    Title="{Binding PageTitle}">

    <Grid RowDefinitions="Auto,*,Auto" BackgroundColor="{StaticResource BackgroundDark}">
        <Grid
            Grid.Row="0"
            Padding="12,10"
            ColumnDefinitions="48,*,Auto"
            ColumnSpacing="10"
            BackgroundColor="{StaticResource SurfaceDark}">
            <Button
                Text="‹"
                Padding="0"
                Clicked="OnBackClicked"
                Style="{StaticResource CompactButtonStyle}"
                SemanticProperties.Description="Go back" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label
                    Text="{Binding PageTitle}"
                    Style="{StaticResource SectionTitleStyle}"
                    LineBreakMode="TailTruncation" />
                <Label
                    Text="Define exercises and sets"
                    Style="{StaticResource CaptionStyle}" />
            </VerticalStackLayout>
            <Button
                Grid.Column="2"
                Text="Save"
                Command="{Binding SaveCommand}"
                IsEnabled="{Binding IsNotBusy}"
                Style="{StaticResource CompactPrimaryButtonStyle}" />
        </Grid>

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding SelectedExercises}"
            IsGrouped="True"
            SelectionMode="None"
            ItemSizingStrategy="MeasureFirstItem">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="3" />
            </CollectionView.ItemsLayout>

            <CollectionView.Header>
                <VerticalStackLayout
                    x:DataType="viewModels:RoutineEditViewModel"
                    Padding="14,16,14,12"
                    Spacing="18">
                    <VerticalStackLayout Spacing="7">
                        <Label Text="{x:Static strings:AppText.NameLabel}" Style="{StaticResource FormLabelStyle}" />
                        <Entry
                            Text="{Binding Name}"
                            Placeholder="{x:Static strings:AppText.RoutineNamePlaceholder}"
                            MaxLength="100" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="{x:Static strings:AppText.AddExerciseToRoutine}" Style="{StaticResource SectionTitleStyle}" />
                        <Button
                            Text="+ Add exercise"
                            Clicked="OnAddExerciseClicked"
                            IsEnabled="{Binding HasAvailableExercises}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </VerticalStackLayout>

                    <Label
                        Text="{x:Static strings:AppText.EmptyRoutineDescription}"
                        IsVisible="{Binding IsSelectionEmpty}"
                        Style="{StaticResource BodyMutedStyle}" />
                    <Label
                        Text="{Binding ErrorMessage}"
                        IsVisible="{Binding HasError}"
                        Style="{StaticResource ErrorLabelStyle}" />
                </VerticalStackLayout>
            </CollectionView.Header>

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="viewModels:RoutineExerciseItem">
                    <VerticalStackLayout Padding="14,18,14,6" Spacing="12">
                                <Grid ColumnDefinitions="58,*,48" ColumnSpacing="10">
                                    <Border
                                        HeightRequest="58"
                                        WidthRequest="58"
                                        Padding="0"
                                        BackgroundColor="White"
                                        Stroke="{StaticResource OutlineDark}">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="29" />
                                        </Border.StrokeShape>
                                        <Image Source="{Binding ImageSource}" Aspect="AspectFill" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label
                                            Text="{Binding Name}"
                                            Style="{StaticResource SectionTitleStyle}"
                                            TextColor="{StaticResource Accent}"
                                            LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Details}" Style="{StaticResource CaptionStyle}" />
                                    </VerticalStackLayout>
                                    <Button
                                        Grid.Column="2"
                                        Text="⋮"
                                        Padding="0"
                                        Clicked="OnExerciseMenuClicked"
                                        Style="{StaticResource CompactButtonStyle}"
                                        SemanticProperties.Description="Exercise options" />
                                </Grid>

                                <Grid ColumnDefinitions="48,*,*,58" ColumnSpacing="8" Padding="4,0">
                                    <Label Text="SET" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="1" Text="KG" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="2" Text="REPS" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="3" Text="RPE" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                                </Grid>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:RoutineSetItem">
                    <SwipeView Margin="14,0">
                                                <SwipeView.RightItems>
                                                    <SwipeItems Mode="Reveal">
                                                        <SwipeItem
                                                            Text="{x:Static strings:AppText.Delete}"
                                                            BackgroundColor="{StaticResource Danger}"
                                                            Command="{Binding Source={x:Reference RoutineEditPageRoot}, Path=BindingContext.DeleteSetCommand}"
                                                            CommandParameter="{Binding .}" />
                                                    </SwipeItems>
                                                </SwipeView.RightItems>
                                                <Grid
                                                    ColumnDefinitions="48,*,*,58"
                                                    ColumnSpacing="8"
                                                    Padding="4,5"
                                                    BackgroundColor="{StaticResource SurfaceDark}">
                                                    <Button
                                                        Text="{Binding CompactSetLabel}"
                                                        Padding="0"
                                                        Clicked="OnSetTypeClicked"
                                                        Style="{StaticResource CompactButtonStyle}"
                                                        SemanticProperties.Hint="Tap to switch between a warm-up and a working set">
                                                        <Button.Triggers>
                                                            <DataTrigger TargetType="Button" Binding="{Binding IsWarmup}" Value="True">
                                                                <Setter Property="TextColor" Value="{StaticResource Warning}" />
                                                                <Setter Property="BorderColor" Value="{StaticResource Warning}" />
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Button" Binding="{Binding SetType}" Value="{x:Static models:TrainingSetType.Failure}">
                                                                <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                                                <Setter Property="BorderColor" Value="{StaticResource Danger}" />
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Button" Binding="{Binding SetType}" Value="{x:Static models:TrainingSetType.Drop}">
                                                                <Setter Property="TextColor" Value="{StaticResource Accent}" />
                                                                <Setter Property="BorderColor" Value="{StaticResource Accent}" />
                                                            </DataTrigger>
                                                        </Button.Triggers>
                                                    </Button>
                                                    <controls:DecimalEntry
                                                        Grid.Column="1"
                                                        Text="{Binding WeightText}"
                                                        Placeholder="0"
                                                        HorizontalTextAlignment="Center"
                                                        SemanticProperties.Description="{x:Static strings:AppText.WeightKgLabel}" />
                                                    <Entry
                                                        Grid.Column="2"
                                                        Text="{Binding RepetitionsText}"
                                                        Placeholder="0"
                                                        Keyboard="Numeric"
                                                        HorizontalTextAlignment="Center"
                                                        SemanticProperties.Description="{x:Static strings:AppText.RepetitionsLabel}" />
                                                    <Button
                                                        Grid.Column="3"
                                                        Text="{Binding RpeLabel}"
                                                        Padding="0"
                                                        Clicked="OnRpeClicked"
                                                        Style="{StaticResource CompactButtonStyle}"
                                                        SemanticProperties.Description="Select RPE from 0 to 10" />
                                                </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.GroupFooterTemplate>
                <DataTemplate x:DataType="viewModels:RoutineExerciseItem">
                    <Button
                        Margin="14,8,14,10"
                        Text="+ Add set"
                        Command="{Binding Source={x:Reference RoutineEditPageRoot}, Path=BindingContext.AddSetCommand}"
                        CommandParameter="{Binding .}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </DataTemplate>
            </CollectionView.GroupFooterTemplate>

            <CollectionView.Footer>
                <Label
                    x:DataType="viewModels:RoutineEditViewModel"
                    Margin="14,8,14,36"
                    Text="Tap a set number to choose its type."
                    IsVisible="{Binding HasSelectedExercises}"
                    Style="{StaticResource CaptionStyle}"
                    HorizontalTextAlignment="Center" />
            </CollectionView.Footer>
        </CollectionView>

        <ActivityIndicator
            Grid.Row="2"
            Margin="0,8"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Color="{StaticResource Accent}" />

        <Grid
            x:Name="BottomSheetOverlay"
            Grid.RowSpan="3"
            ZIndex="100"
            IsVisible="False"
            BackgroundColor="#B3000000">
            <BoxView BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBottomSheetBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                Margin="10,0,10,12"
                Padding="0,8,0,14"
                VerticalOptions="End"
                BackgroundColor="{StaticResource SurfaceRaisedDark}"
                Stroke="{StaticResource OutlineDark}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <BoxView
                        Margin="0,0,0,8"
                        HeightRequest="4"
                        WidthRequest="52"
                        CornerRadius="2"
                        Color="{StaticResource Accent}"
                        HorizontalOptions="Center" />

                    <Grid Padding="20,8,12,12" ColumnDefinitions="*,48">
                        <Label
                            x:Name="BottomSheetTitle"
                            Text="Options"
                            Style="{StaticResource SectionTitleStyle}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Text="×"
                            Padding="0"
                            Clicked="OnBottomSheetCloseClicked"
                            Style="{StaticResource CompactButtonStyle}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineDark}" />

                    <VerticalStackLayout x:Name="SetTypeSheetContent" IsVisible="False" Padding="12,8" Spacing="6">
                        <Button Text="W   Warm Up Set" TextColor="{StaticResource Warning}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Warning}" BorderWidth="1" CommandParameter="Warmup" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="1   Normal Set" TextColor="{StaticResource TextPrimaryDark}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource OutlineDark}" BorderWidth="1" CommandParameter="Normal" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="F   Failure Set" TextColor="{StaticResource Danger}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Danger}" BorderWidth="1" CommandParameter="Failure" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="D   Drop Set" TextColor="{StaticResource Accent}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Accent}" BorderWidth="1" CommandParameter="Drop" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="×   Remove Set" TextColor="{StaticResource Danger}" BackgroundColor="Transparent" BorderColor="{StaticResource Danger}" BorderWidth="1" CommandParameter="Remove" Clicked="OnSetTypeOptionClicked" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="RpeSheetContent" IsVisible="False" Padding="14,10" Spacing="12">
                        <Label
                            x:Name="SelectedRpeValueLabel"
                            Text="0"
                            FontSize="64"
                            HorizontalTextAlignment="Center"
                            TextColor="{StaticResource TextPrimaryDark}" />
                        <Label Text="Select RPE" Style="{StaticResource SectionTitleStyle}" HorizontalTextAlignment="Center" />
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*,*" ColumnSpacing="3">
                            <Button Grid.Column="0" Text="6" Padding="0" CommandParameter="6" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="1" Text="7" Padding="0" CommandParameter="7" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="2" Text="7.5" Padding="0" CommandParameter="7.5" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="3" Text="8" Padding="0" CommandParameter="8" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="4" Text="8.5" Padding="0" CommandParameter="8.5" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="5" Text="9" Padding="0" CommandParameter="9" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="6" Text="9.5" Padding="0" CommandParameter="9.5" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="7" Text="10" Padding="0" CommandParameter="10" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Button Text="Clear" Clicked="OnRpeClearClicked" Style="{StaticResource CompactDangerButtonStyle}" />
                            <Button Grid.Column="1" Text="Done  ✓" Clicked="OnRpeDoneClicked" Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="ExerciseSheetContent" IsVisible="False" Padding="12,8" Spacing="6">
                        <Button Text="↑   Move up" TextColor="{StaticResource TextPrimaryDark}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource OutlineDark}" BorderWidth="1" CommandParameter="MoveUp" Clicked="OnExerciseOptionClicked" />
                        <Button Text="↓   Move down" TextColor="{StaticResource TextPrimaryDark}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource OutlineDark}" BorderWidth="1" CommandParameter="MoveDown" Clicked="OnExerciseOptionClicked" />
                        <Button Text="↻   Replace exercise" TextColor="{StaticResource Accent}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Accent}" BorderWidth="1" CommandParameter="Replace" Clicked="OnExerciseOptionClicked" />
                        <Button Text="×   Remove exercise" TextColor="{StaticResource Danger}" BackgroundColor="Transparent" BorderColor="{StaticResource Danger}" BorderWidth="1" CommandParameter="Remove" Clicked="OnExerciseOptionClicked" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
