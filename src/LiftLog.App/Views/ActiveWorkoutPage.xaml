<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LiftLog.App.Views.ActiveWorkoutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LiftLog.App.Controls"
    xmlns:strings="clr-namespace:LiftLog.App.Resources.Strings"
    xmlns:viewModels="clr-namespace:LiftLog.App.ViewModels"
    xmlns:models="clr-namespace:LiftLog.Core.Models;assembly=LiftLog.Core"
    x:Name="ActiveWorkoutPageRoot"
    x:DataType="viewModels:ActiveWorkoutViewModel"
    Shell.NavBarIsVisible="False"
    Title="{x:Static strings:AppText.ActiveWorkoutTitle}">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" BackgroundColor="{StaticResource BackgroundDark}">
        <Grid
            Grid.Row="0"
            Padding="12,10"
            ColumnDefinitions="48,*,Auto"
            ColumnSpacing="10"
            BackgroundColor="{StaticResource SurfaceDark}">
            <Button
                Text="⌄"
                Padding="0"
                Clicked="OnMinimizeClicked"
                Style="{StaticResource CompactButtonStyle}"
                SemanticProperties.Description="Minimize workout" />
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                <Label
                    Text="{Binding RoutineName}"
                    Style="{StaticResource SectionTitleStyle}"
                    LineBreakMode="TailTruncation"
                    MaxLines="1" />
                <Label
                    Text="{x:Static strings:AppText.WorkoutInProgress}"
                    Style="{StaticResource CaptionStyle}" />
            </VerticalStackLayout>
            <Button
                Grid.Column="2"
                Text="{x:Static strings:AppText.Finish}"
                Clicked="OnFinishClicked"
                Style="{StaticResource CompactPrimaryButtonStyle}" />
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="20,14"
            ColumnDefinitions="*,*,*"
            ColumnSpacing="12"
            BackgroundColor="{StaticResource Black}">
            <VerticalStackLayout Spacing="2">
                <Label Text="{x:Static strings:AppText.DurationLabel}" Style="{StaticResource CaptionStyle}" />
                <Label Text="{Binding DurationText}" Style="{StaticResource CardTitleStyle}" TextColor="{StaticResource Accent}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label Text="{x:Static strings:AppText.VolumeLabel}" Style="{StaticResource CaptionStyle}" />
                <Label Text="{Binding VolumeText}" Style="{StaticResource CardTitleStyle}" />
            </VerticalStackLayout>
            <VerticalStackLayout Grid.Column="2" Spacing="2">
                <Label Text="{x:Static strings:AppText.CompletedSetsLabel}" Style="{StaticResource CaptionStyle}" />
                <Label Text="{Binding CompletedSetsText}" Style="{StaticResource CardTitleStyle}" />
            </VerticalStackLayout>
        </Grid>

        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Exercises}"
            IsGrouped="True"
            ItemSizingStrategy="MeasureAllItems"
            SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="3" />
            </CollectionView.ItemsLayout>

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="viewModels:ActiveWorkoutExerciseItem">
                    <VerticalStackLayout Padding="14,22,14,0" Spacing="12">
                        <Grid ColumnDefinitions="58,*,48" ColumnSpacing="12">
                            <Border
                                HeightRequest="58"
                                WidthRequest="58"
                                Padding="0"
                                BackgroundColor="White"
                                Stroke="{StaticResource OutlineDark}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="29" />
                                </Border.StrokeShape>
                                <Image Source="{Binding ImageSource}" Aspect="AspectFill" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label
                                    Text="{Binding Name}"
                                    Style="{StaticResource SectionTitleStyle}"
                                    TextColor="{StaticResource Accent}"
                                    LineBreakMode="WordWrap" />
                                <Label
                                    Text="{Binding PreviousPerformance}"
                                    Style="{StaticResource CaptionStyle}"
                                    LineBreakMode="TailTruncation"
                                    MaxLines="2" />
                            </VerticalStackLayout>
                            <Button
                                Grid.Column="2"
                                Text="⋮"
                                Padding="0"
                                Clicked="OnExerciseMenuClicked"
                                Style="{StaticResource CompactButtonStyle}"
                                SemanticProperties.Description="Exercise options" />
                        </Grid>

                        <Entry
                            Text="{Binding Notes, Mode=TwoWay}"
                            Placeholder="{x:Static strings:AppText.ExerciseNotesPlaceholder}"
                            MaxLength="2000"
                            ReturnType="Done"
                            ClearButtonVisibility="WhileEditing"
                            BackgroundColor="Transparent"
                            Margin="0,-6,0,-4"
                            Unfocused="OnExerciseNotesUnfocused"
                            SemanticProperties.Description="Exercise notes" />

                        <Border
                            Padding="10,8"
                            BackgroundColor="Transparent"
                            Stroke="{StaticResource Accent}"
                            StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Tapped="OnRestTimerClicked"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="9">
                                <Label
                                    Text="⏱"
                                    FontSize="18"
                                    TextColor="{StaticResource Accent}"
                                    VerticalTextAlignment="Center" />
                                <Label
                                    Grid.Column="1"
                                    Text="{Binding RestTimerLabel}"
                                    Style="{StaticResource AccentCaptionStyle}"
                                    FontSize="14"
                                    VerticalTextAlignment="Center" />
                                <Label
                                    Grid.Column="2"
                                    Text="›"
                                    FontSize="24"
                                    TextColor="{StaticResource Accent}"
                                    VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="36,96,*,*,46,40" ColumnSpacing="4" Padding="4,0">
                            <Label Text="SET" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="PREVIOUS" Style="{StaticResource CaptionStyle}" FontSize="10" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="KG" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="REPS" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="RPE" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="✓" Style="{StaticResource CaptionStyle}" HorizontalTextAlignment="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:WorkoutSetItem">
                    <SwipeView Margin="14,0">
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Reveal">
                                <SwipeItem
                                    Text="{x:Static strings:AppText.Delete}"
                                    BackgroundColor="{StaticResource Danger}"
                                    Command="{Binding Source={x:Reference ActiveWorkoutPageRoot}, Path=BindingContext.DeleteSetCommand}"
                                    CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <VerticalStackLayout BackgroundColor="{StaticResource SurfaceDark}" Spacing="0">
                            <VerticalStackLayout.Triggers>
                                <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding IsCompleted}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource SuccessSurface}" />
                                </DataTrigger>
                            </VerticalStackLayout.Triggers>
                            <Grid ColumnDefinitions="36,96,*,*,46,40" ColumnSpacing="4" Padding="4,5">
                                <Button
                                    Text="{Binding CompactSetLabel}"
                                    Padding="0"
                                    Clicked="OnSetTypeClicked"
                                    Style="{StaticResource CompactButtonStyle}"
                                    SemanticProperties.Hint="Tap to switch between a warm-up and a working set">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsWarmup}" Value="True">
                                            <Setter Property="TextColor" Value="{StaticResource Warning}" />
                                            <Setter Property="BorderColor" Value="{StaticResource Warning}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding SetType}" Value="{x:Static models:TrainingSetType.Failure}">
                                            <Setter Property="TextColor" Value="{StaticResource Danger}" />
                                            <Setter Property="BorderColor" Value="{StaticResource Danger}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Button" Binding="{Binding SetType}" Value="{x:Static models:TrainingSetType.Drop}">
                                            <Setter Property="TextColor" Value="{StaticResource Accent}" />
                                            <Setter Property="BorderColor" Value="{StaticResource Accent}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                <Label
                                    Grid.Column="1"
                                    Text="{Binding PreviousPerformance}"
                                    Style="{StaticResource CaptionStyle}"
                                    FontSize="10"
                                    HorizontalTextAlignment="Center"
                                    VerticalTextAlignment="Center"
                                    LineBreakMode="WordWrap"
                                    MaxLines="2" />
                                <controls:DecimalEntry
                                    Grid.Column="2"
                                    Text="{Binding WeightText}"
                                    Placeholder="0"
                                    HorizontalTextAlignment="Center"
                                    SemanticProperties.Description="{x:Static strings:AppText.WeightKgLabel}"
                                    Unfocused="OnSetFieldUnfocused">
                                    <controls:DecimalEntry.Triggers>
                                        <DataTrigger TargetType="controls:DecimalEntry" Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource SuccessSurface}" />
                                        </DataTrigger>
                                    </controls:DecimalEntry.Triggers>
                                </controls:DecimalEntry>
                                <Entry
                                    Grid.Column="3"
                                    Text="{Binding RepetitionsText}"
                                    Placeholder="0"
                                    Keyboard="Numeric"
                                    HorizontalTextAlignment="Center"
                                    SemanticProperties.Description="{x:Static strings:AppText.RepetitionsLabel}"
                                    Unfocused="OnSetFieldUnfocused">
                                    <Entry.Triggers>
                                        <DataTrigger TargetType="Entry" Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource SuccessSurface}" />
                                        </DataTrigger>
                                    </Entry.Triggers>
                                </Entry>
                                <Button
                                    Grid.Column="4"
                                    Text="{Binding RpeLabel}"
                                    Padding="0"
                                    Clicked="OnRpeClicked"
                                    Style="{StaticResource CompactButtonStyle}" />
                                <Button
                                    Grid.Column="5"
                                    Text="{Binding CompletionGlyph}"
                                    Padding="0"
                                    Command="{Binding Source={x:Reference ActiveWorkoutPageRoot}, Path=BindingContext.ToggleSetCompletionCommand}"
                                    CommandParameter="{Binding .}"
                                    Style="{StaticResource CompactButtonStyle}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
                                            <Setter Property="TextColor" Value="{StaticResource Black}" />
                                            <Setter Property="BorderColor" Value="{StaticResource Success}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </Grid>
                            <Label
                                Text="{x:Static strings:AppText.NewWeightRecord}"
                                IsVisible="{Binding IsPersonalRecord}"
                                Style="{StaticResource AccentCaptionStyle}"
                                Margin="140,0,8,6" />
                        </VerticalStackLayout>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.GroupFooterTemplate>
                <DataTemplate x:DataType="viewModels:ActiveWorkoutExerciseItem">
                    <Button
                        Margin="14,6,14,4"
                        Text="+ Add set"
                        Command="{Binding Source={x:Reference ActiveWorkoutPageRoot}, Path=BindingContext.AddSetCommand}"
                        CommandParameter="{Binding .}"
                        Style="{StaticResource SecondaryButtonStyle}" />
                </DataTemplate>
            </CollectionView.GroupFooterTemplate>

            <CollectionView.Footer>
                <VerticalStackLayout Padding="14,20,14,36" Spacing="24">
                    <Button
                        Text="+ Add exercise"
                        Clicked="OnAddExerciseClicked"
                        Style="{StaticResource PrimaryButtonStyle}" />

                    <Grid
                        IsVisible="{Binding Source={x:Reference ActiveWorkoutPageRoot}, Path=BindingContext.HasError}"
                        ColumnDefinitions="*,Auto"
                        ColumnSpacing="10">
                        <Label
                            Text="{Binding Source={x:Reference ActiveWorkoutPageRoot}, Path=BindingContext.ErrorMessage}"
                            Style="{StaticResource ErrorLabelStyle}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Text="{x:Static strings:AppText.Retry}"
                            Command="{Binding Source={x:Reference ActiveWorkoutPageRoot}, Path=BindingContext.RetryCommand}"
                            Style="{StaticResource CompactButtonStyle}" />
                    </Grid>

                    <Button
                        Text="{x:Static strings:AppText.CancelWorkout}"
                        Clicked="OnCancelClicked"
                        Style="{StaticResource CompactDangerButtonStyle}"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.Footer>
        </CollectionView>

        <Border
            Grid.Row="3"
            Margin="12,0,12,10"
            Padding="14,10"
            IsVisible="{Binding IsRestTimerRunning}"
            BackgroundColor="{StaticResource SurfaceRaisedDark}"
            Stroke="{StaticResource Accent}"
            StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="14" />
            </Border.StrokeShape>
            <Grid ColumnDefinitions="*,Auto,44" ColumnSpacing="10">
                <VerticalStackLayout Spacing="1" VerticalOptions="Center">
                    <Label
                        Text="{Binding RestTimerExerciseName}"
                        Style="{StaticResource CaptionStyle}"
                        LineBreakMode="TailTruncation"
                        MaxLines="1" />
                    <Label
                        Text="{Binding RestTimerRemainingText}"
                        FontFamily="OpenSansSemibold"
                        FontSize="24"
                        TextColor="{StaticResource Accent}" />
                </VerticalStackLayout>
                <Button
                    Grid.Column="1"
                    Text="+30s"
                    Command="{Binding AddRestTimeCommand}"
                    Style="{StaticResource CompactButtonStyle}"
                    SemanticProperties.Description="{x:Static strings:AppText.AddThirtySeconds}" />
                <Button
                    Grid.Column="2"
                    Text="×"
                    Padding="0"
                    Command="{Binding StopRestTimerCommand}"
                    Style="{StaticResource CompactButtonStyle}"
                    SemanticProperties.Description="{x:Static strings:AppText.StopRestTimer}" />
            </Grid>
        </Border>

        <Grid
            Grid.RowSpan="5"
            ZIndex="50"
            IsVisible="{Binding IsPreparing}"
            BackgroundColor="#E608090B">
            <VerticalStackLayout
                Spacing="14"
                HorizontalOptions="Center"
                VerticalOptions="Center">
                <ActivityIndicator
                    IsRunning="{Binding IsPreparing}"
                    Color="{StaticResource Accent}"
                    WidthRequest="42"
                    HeightRequest="42" />
                <Label
                    Text="{x:Static strings:AppText.PreparingWorkout}"
                    Style="{StaticResource BodyMutedStyle}"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

        <Grid
            x:Name="BottomSheetOverlay"
            Grid.RowSpan="5"
            ZIndex="100"
            IsVisible="False"
            BackgroundColor="#B3000000">
            <BoxView BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBottomSheetBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                Margin="10,0,10,12"
                Padding="0,8,0,14"
                VerticalOptions="End"
                BackgroundColor="{StaticResource SurfaceRaisedDark}"
                Stroke="{StaticResource OutlineDark}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <BoxView
                        Margin="0,0,0,8"
                        HeightRequest="4"
                        WidthRequest="52"
                        CornerRadius="2"
                        Color="{StaticResource Accent}"
                        HorizontalOptions="Center" />

                    <Grid Padding="20,8,12,12" ColumnDefinitions="*,48">
                        <Label
                            x:Name="BottomSheetTitle"
                            Text="Options"
                            Style="{StaticResource SectionTitleStyle}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Text="×"
                            Padding="0"
                            Clicked="OnBottomSheetCloseClicked"
                            Style="{StaticResource CompactButtonStyle}" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineDark}" />

                    <VerticalStackLayout x:Name="SetTypeSheetContent" IsVisible="False" Padding="12,8" Spacing="6">
                        <Button Text="W   Warm Up Set" TextColor="{StaticResource Warning}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Warning}" BorderWidth="1" CommandParameter="Warmup" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="1   Normal Set" TextColor="{StaticResource TextPrimaryDark}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource OutlineDark}" BorderWidth="1" CommandParameter="Normal" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="F   Failure Set" TextColor="{StaticResource Danger}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Danger}" BorderWidth="1" CommandParameter="Failure" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="D   Drop Set" TextColor="{StaticResource Accent}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Accent}" BorderWidth="1" CommandParameter="Drop" Clicked="OnSetTypeOptionClicked" />
                        <Button Text="×   Remove Set" TextColor="{StaticResource Danger}" BackgroundColor="Transparent" BorderColor="{StaticResource Danger}" BorderWidth="1" CommandParameter="Remove" Clicked="OnSetTypeOptionClicked" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="RpeSheetContent" IsVisible="False" Padding="14,10" Spacing="12">
                        <Label
                            x:Name="SelectedRpeValueLabel"
                            Text="0"
                            FontSize="64"
                            HorizontalTextAlignment="Center"
                            TextColor="{StaticResource TextPrimaryDark}" />
                        <Label Text="Select RPE" Style="{StaticResource SectionTitleStyle}" HorizontalTextAlignment="Center" />
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*,*" ColumnSpacing="3">
                            <Button Grid.Column="0" Text="6" Padding="0" CommandParameter="6" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="1" Text="7" Padding="0" CommandParameter="7" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="2" Text="7.5" Padding="0" CommandParameter="7.5" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="3" Text="8" Padding="0" CommandParameter="8" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="4" Text="8.5" Padding="0" CommandParameter="8.5" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="5" Text="9" Padding="0" CommandParameter="9" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="6" Text="9.5" Padding="0" CommandParameter="9.5" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="7" Text="10" Padding="0" CommandParameter="10" Clicked="OnRpeOptionClicked" Style="{StaticResource CompactButtonStyle}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <Button Text="Clear" Clicked="OnRpeClearClicked" Style="{StaticResource CompactDangerButtonStyle}" />
                            <Button Grid.Column="1" Text="Done  ✓" Clicked="OnRpeDoneClicked" Style="{StaticResource PrimaryButtonStyle}" />
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="RestTimerSheetContent" IsVisible="False" Padding="18,12" Spacing="16">
                        <Label
                            x:Name="RestTimerExerciseNameLabel"
                            Style="{StaticResource BodyMutedStyle}"
                            HorizontalTextAlignment="Center"
                            LineBreakMode="TailTruncation"
                            MaxLines="1" />
                        <Label
                            x:Name="SelectedRestTimerLabel"
                            Text="OFF"
                            FontFamily="OpenSansSemibold"
                            FontSize="48"
                            TextColor="{StaticResource TextPrimaryDark}"
                            HorizontalTextAlignment="Center" />
                        <Grid ColumnDefinitions="64,*,64" ColumnSpacing="12">
                            <Button
                                Text="−15"
                                CommandParameter="-15"
                                Clicked="OnRestTimerAdjustClicked"
                                Style="{StaticResource CompactButtonStyle}" />
                            <Label
                                Grid.Column="1"
                                Text="Adjust in 15 second steps"
                                Style="{StaticResource CaptionStyle}"
                                HorizontalTextAlignment="Center"
                                VerticalTextAlignment="Center" />
                            <Button
                                Grid.Column="2"
                                Text="+15"
                                CommandParameter="15"
                                Clicked="OnRestTimerAdjustClicked"
                                Style="{StaticResource CompactButtonStyle}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="6">
                            <Button Grid.Column="0" Text="OFF" CommandParameter="0" Clicked="OnRestTimerPresetClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="1" Text="1m" CommandParameter="60" Clicked="OnRestTimerPresetClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="2" Text="1:30" CommandParameter="90" Clicked="OnRestTimerPresetClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="3" Text="2m" CommandParameter="120" Clicked="OnRestTimerPresetClicked" Style="{StaticResource CompactButtonStyle}" />
                            <Button Grid.Column="4" Text="3m" CommandParameter="180" Clicked="OnRestTimerPresetClicked" Style="{StaticResource CompactButtonStyle}" />
                        </Grid>
                        <Button
                            Text="{x:Static strings:AppText.Done}"
                            Clicked="OnRestTimerDoneClicked"
                            Style="{StaticResource PrimaryButtonStyle}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout x:Name="ExerciseSheetContent" IsVisible="False" Padding="12,8" Spacing="6">
                        <Button Text="↑   Move up" TextColor="{StaticResource TextPrimaryDark}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource OutlineDark}" BorderWidth="1" CommandParameter="MoveUp" Clicked="OnExerciseOptionClicked" />
                        <Button Text="↓   Move down" TextColor="{StaticResource TextPrimaryDark}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource OutlineDark}" BorderWidth="1" CommandParameter="MoveDown" Clicked="OnExerciseOptionClicked" />
                        <Button Text="↻   Replace exercise" TextColor="{StaticResource Accent}" BackgroundColor="{StaticResource SurfaceDark}" BorderColor="{StaticResource Accent}" BorderWidth="1" CommandParameter="Replace" Clicked="OnExerciseOptionClicked" />
                        <Button Text="×   Remove exercise" TextColor="{StaticResource Danger}" BackgroundColor="Transparent" BorderColor="{StaticResource Danger}" BorderWidth="1" CommandParameter="Remove" Clicked="OnExerciseOptionClicked" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid
            x:Name="FinishWorkoutOverlay"
            Grid.RowSpan="5"
            ZIndex="200"
            IsVisible="False"
            BackgroundColor="#B3000000">
            <BoxView BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFinishWorkoutBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                Margin="24"
                Padding="24"
                MaximumWidthRequest="420"
                HorizontalOptions="Fill"
                VerticalOptions="Center"
                BackgroundColor="{StaticResource SurfaceRaisedDark}"
                Stroke="{StaticResource Accent}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">
                    <Border
                        HeightRequest="56"
                        WidthRequest="56"
                        Padding="0"
                        HorizontalOptions="Center"
                        BackgroundColor="#263F7CFF"
                        Stroke="{StaticResource Accent}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28" />
                        </Border.StrokeShape>
                        <Label
                            Text="✓"
                            FontFamily="OpenSansSemibold"
                            FontSize="28"
                            TextColor="{StaticResource Accent}"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="{x:Static strings:AppText.FinishWorkout}"
                            Style="{StaticResource SectionTitleStyle}"
                            HorizontalTextAlignment="Center" />
                        <Label
                            x:Name="FinishWorkoutMessageLabel"
                            Style="{StaticResource BodyMutedStyle}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <Border
                        Padding="14"
                        BackgroundColor="{StaticResource SurfaceDark}"
                        Stroke="{StaticResource OutlineDark}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,1,*" ColumnSpacing="14">
                            <VerticalStackLayout Spacing="2">
                                <Label
                                    Text="{Binding CompletedSetsText}"
                                    Style="{StaticResource CardTitleStyle}"
                                    TextColor="{StaticResource Accent}"
                                    HorizontalTextAlignment="Center" />
                                <Label
                                    Text="{x:Static strings:AppText.CompletedSetsLabel}"
                                    Style="{StaticResource CaptionStyle}"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                            <BoxView
                                Grid.Column="1"
                                WidthRequest="1"
                                Color="{StaticResource OutlineDark}" />
                            <VerticalStackLayout Grid.Column="2" Spacing="2">
                                <Label
                                    Text="{Binding VolumeText}"
                                    Style="{StaticResource CardTitleStyle}"
                                    TextColor="{StaticResource Accent}"
                                    HorizontalTextAlignment="Center" />
                                <Label
                                    Text="{x:Static strings:AppText.VolumeLabel}"
                                    Style="{StaticResource CaptionStyle}"
                                    HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <VerticalStackLayout Spacing="10">
                        <Button
                            Text="{x:Static strings:AppText.Finish}"
                            Clicked="OnConfirmFinishWorkoutClicked"
                            Style="{StaticResource PrimaryButtonStyle}" />
                        <Button
                            Text="{x:Static strings:AppText.KeepTraining}"
                            Clicked="OnKeepWorkoutOpenClicked"
                            Style="{StaticResource SecondaryButtonStyle}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid
            x:Name="CancelWorkoutOverlay"
            Grid.RowSpan="5"
            ZIndex="200"
            IsVisible="False"
            BackgroundColor="#B3000000">
            <BoxView BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCancelWorkoutBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                Margin="24"
                Padding="24"
                MaximumWidthRequest="420"
                HorizontalOptions="Fill"
                VerticalOptions="Center"
                BackgroundColor="{StaticResource SurfaceRaisedDark}"
                Stroke="{StaticResource OutlineDark}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="18">
                    <Border
                        HeightRequest="56"
                        WidthRequest="56"
                        Padding="0"
                        HorizontalOptions="Center"
                        BackgroundColor="#26D65A50"
                        Stroke="{StaticResource Danger}"
                        StrokeThickness="1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="28" />
                        </Border.StrokeShape>
                        <Label
                            Text="!"
                            FontFamily="OpenSansSemibold"
                            FontSize="28"
                            TextColor="{StaticResource Danger}"
                            HorizontalTextAlignment="Center"
                            VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Spacing="8">
                        <Label
                            Text="{x:Static strings:AppText.CancelWorkout}"
                            Style="{StaticResource SectionTitleStyle}"
                            HorizontalTextAlignment="Center" />
                        <Label
                            Text="{x:Static strings:AppText.CancelWorkoutConfirmation}"
                            Style="{StaticResource BodyMutedStyle}"
                            HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="10">
                        <Button
                            Text="{x:Static strings:AppText.KeepTraining}"
                            Clicked="OnKeepTrainingClicked"
                            Style="{StaticResource PrimaryButtonStyle}" />
                        <Button
                            Text="{x:Static strings:AppText.CancelWorkout}"
                            Clicked="OnConfirmCancelWorkoutClicked"
                            Style="{StaticResource DangerButtonStyle}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
