<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="LiftLog.App.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:LiftLog.App.Controls"
    xmlns:components="clr-namespace:LiftLog.App.Views.Components"
    xmlns:strings="clr-namespace:LiftLog.App.Resources.Strings"
    xmlns:viewModels="clr-namespace:LiftLog.App.ViewModels"
    x:Name="ProfilePageRoot"
    x:DataType="viewModels:ProfileViewModel"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <Style x:Key="ProfileMetricButtonStyle" TargetType="Button" BasedOn="{StaticResource CompactButtonStyle}">
            <Setter Property="BorderColor" Value="Transparent" />
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceRaisedDark}" />
            <Setter Property="TextColor" Value="{StaticResource TextPrimaryDark}" />
        </Style>
        <Style x:Key="ProfileDashboardButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="HeightRequest" Value="62" />
            <Setter Property="HorizontalOptions" Value="Fill" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">
        <ScrollView>
            <VerticalStackLayout Padding="20,24,20,36" Spacing="24">
                <Grid ColumnDefinitions="*,48" ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{x:Static strings:AppText.ProfileEyebrow}" Style="{StaticResource AccentCaptionStyle}" />
                        <Label Text="{x:Static strings:AppText.YourTrainingTitle}" Style="{StaticResource PageTitleStyle}" />
                    </VerticalStackLayout>
                    <ImageButton
                        Grid.Column="1"
                        Source="settings.svg"
                        Command="{Binding OpenSettingsCommand}"
                        BackgroundColor="Transparent"
                        HeightRequest="48"
                        WidthRequest="48"
                        Padding="10"
                        SemanticProperties.Description="Settings"
                        ToolTipProperties.Text="Settings" />
                </Grid>

                <Border Style="{StaticResource CardStyle}" Padding="0,16">
                    <Grid ColumnDefinitions="*,1,*,1,*">
                        <VerticalStackLayout Spacing="3">
                            <Label Text="{Binding TotalWorkouts}" Style="{StaticResource MetricValueStyle}" />
                            <Label Text="{x:Static strings:AppText.WorkoutsCountLabel}" Style="{StaticResource MetricLabelStyle}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="1" Color="{StaticResource OutlineDark}" WidthRequest="1" />
                        <VerticalStackLayout Grid.Column="2" Spacing="3">
                            <Label Text="{Binding TotalVolume}" Style="{StaticResource MetricValueStyle}" FontSize="16" MaxLines="1" />
                            <Label Text="{x:Static strings:AppText.TotalVolumeLabel}" Style="{StaticResource MetricLabelStyle}" />
                        </VerticalStackLayout>
                        <BoxView Grid.Column="3" Color="{StaticResource OutlineDark}" WidthRequest="1" />
                        <VerticalStackLayout Grid.Column="4" Spacing="3">
                            <Label Text="{Binding TotalDuration}" Style="{StaticResource MetricValueStyle}" FontSize="16" MaxLines="1" />
                            <Label Text="{x:Static strings:AppText.TotalTimeLabel}" Style="{StaticResource MetricLabelStyle}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding ChartValue}" Style="{StaticResource SectionTitleStyle}" />
                            <Label Text="{Binding SelectedPeriod.Name}" Style="{StaticResource CaptionStyle}" />
                        </VerticalStackLayout>
                        <Button
                            Grid.Column="1"
                            WidthRequest="154"
                            Text="{Binding SelectedPeriod.Name}"
                            Clicked="OnPeriodPickerClicked"
                            Style="{StaticResource CompactButtonStyle}"
                            SemanticProperties.Description="Chart period" />
                    </Grid>

                    <Grid HeightRequest="230">
                        <controls:TrainingChartView
                            Points="{Binding ChartPoints}"
                            SemanticProperties.Description="Training history chart" />
                        <Label
                            Text="{x:Static strings:AppText.NoWorkoutsInPeriod}"
                            IsVisible="{Binding IsChartEmpty}"
                            Style="{StaticResource BodyMutedStyle}"
                            HorizontalTextAlignment="Center"
                            HorizontalOptions="Center"
                            VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button
                            Text="{x:Static strings:AppText.VolumeLabel}"
                            Command="{Binding SelectMetricCommand}"
                            CommandParameter="Volume"
                            Style="{StaticResource ProfileMetricButtonStyle}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsVolumeSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                    <Setter Property="TextColor" Value="{StaticResource Black}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button
                            Grid.Column="1"
                            Text="{x:Static strings:AppText.DurationLabel}"
                            Command="{Binding SelectMetricCommand}"
                            CommandParameter="Duration"
                            Style="{StaticResource ProfileMetricButtonStyle}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsDurationSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                    <Setter Property="TextColor" Value="{StaticResource Black}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button
                            Grid.Column="2"
                            Text="{x:Static strings:AppText.SetsLabel}"
                            Command="{Binding SelectMetricCommand}"
                            CommandParameter="Sets"
                            Style="{StaticResource ProfileMetricButtonStyle}">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsSetsSelected}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Accent}" />
                                    <Setter Property="TextColor" Value="{StaticResource Black}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Label Text="{x:Static strings:AppText.DashboardTitle}" Style="{StaticResource SectionTitleStyle}" />
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                        <Button Text="{x:Static strings:AppText.StatisticsTitle}" Command="{Binding OpenExerciseProgressCommand}" Style="{StaticResource ProfileDashboardButtonStyle}" />
                        <Button Grid.Column="1" Text="{x:Static strings:AppText.ExercisesTitle}" Command="{Binding OpenExercisesCommand}" Style="{StaticResource ProfileDashboardButtonStyle}" />
                        <Button Grid.Row="1" Text="{x:Static strings:AppText.CalendarTitle}" Command="{Binding OpenCalendarCommand}" Style="{StaticResource ProfileDashboardButtonStyle}" />
                        <Button Grid.Row="1" Grid.Column="1" Text="{x:Static strings:AppText.MeasurementsTitle}" Command="{Binding OpenMeasurementsCommand}" Style="{StaticResource ProfileDashboardButtonStyle}" />
                    </Grid>
                </VerticalStackLayout>

                <Border Style="{StaticResource StatusCardStyle}" IsVisible="{Binding HasError}">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabelStyle}" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="{x:Static strings:AppText.Retry}" Command="{Binding RetryCommand}" Style="{StaticResource CompactButtonStyle}" />
                    </Grid>
                </Border>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Accent}" />
            </VerticalStackLayout>
        </ScrollView>

        <components:ActiveWorkoutBannerView x:Name="ActiveWorkoutBanner" Grid.Row="1" />

        <Grid
            x:Name="PeriodPickerOverlay"
            Grid.RowSpan="2"
            ZIndex="100"
            IsVisible="False"
            BackgroundColor="#B3000000">
            <BoxView BackgroundColor="Transparent">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPeriodPickerBackdropTapped" />
                </BoxView.GestureRecognizers>
            </BoxView>

            <Border
                Margin="10,0,10,12"
                Padding="0,8,0,14"
                VerticalOptions="End"
                BackgroundColor="{StaticResource SurfaceRaisedDark}"
                Stroke="{StaticResource OutlineDark}"
                StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="0">
                    <BoxView
                        Margin="0,0,0,8"
                        HeightRequest="4"
                        WidthRequest="52"
                        CornerRadius="2"
                        Color="{StaticResource Accent}"
                        HorizontalOptions="Center" />
                    <Grid Padding="20,8,12,12" ColumnDefinitions="*,48">
                        <Label
                            Text="{x:Static strings:AppText.SelectPeriod}"
                            Style="{StaticResource SectionTitleStyle}"
                            VerticalOptions="Center" />
                        <Button
                            Grid.Column="1"
                            Text="&#x00D7;"
                            Padding="0"
                            Clicked="OnPeriodPickerCloseClicked"
                            Style="{StaticResource CompactButtonStyle}"
                            SemanticProperties.Description="Close period selector" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="{StaticResource OutlineDark}" />
                    <VerticalStackLayout Padding="12,10" Spacing="7">
                        <Button
                            x:Name="LastMonthButton"
                            Text="{x:Static strings:AppText.LastMonth}"
                            CommandParameter="LastMonth"
                            Clicked="OnPeriodOptionClicked"
                            BackgroundColor="{StaticResource SurfaceDark}"
                            BorderColor="{StaticResource OutlineDark}" />
                        <Button
                            x:Name="ThreeMonthsButton"
                            Text="{x:Static strings:AppText.LastThreeMonths}"
                            CommandParameter="ThreeMonths"
                            Clicked="OnPeriodOptionClicked"
                            BackgroundColor="{StaticResource SurfaceDark}"
                            BorderColor="{StaticResource OutlineDark}" />
                        <Button
                            x:Name="OneYearButton"
                            Text="{x:Static strings:AppText.LastYear}"
                            CommandParameter="OneYear"
                            Clicked="OnPeriodOptionClicked"
                            BackgroundColor="{StaticResource SurfaceDark}"
                            BorderColor="{StaticResource OutlineDark}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
